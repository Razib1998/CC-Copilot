# Kopieren nach .env und Werte setzen.

# Mindestens 32 Zeichen empfohlen (HS256-Signatur).
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Optional: Gültigkeit des Access-Tokens in Sekunden (Standard: 28800 = 8h)
# JWT_EXPIRES_SEC=28800

# Server-Port (Standard: 5371)
# PORT=5371

# Öffentliche App-Basis für generierte Einladungslinks
APP_BASE_URL=http://localhost:5370

# Optionaler Seed (siehe npm run seed:test-user):
# AUTH_SEED_EMAIL=test@cc-cockpit.local
# AUTH_SEED_PASSWORD=TestLocal!2026
# AUTH_SEED_NAME=Testbenutzer

# Phase 5 Demo-Zugriffe: npm run seed:phase5-access
# PHASE5_SECOND_USER=1 — zusätzlich viewer@cc-cockpit.local anlegen
# PHASE5_PROJECT_NAME=Phase-5 Demo

# Phase 6 Demo-Einladung: npm run seed:phase6-invite
# PHASE6_INVITEE_EMAIL=invitee@cc-cockpit.local
# PUBLIC_APP_BASE_URL=http://localhost:5370

# NUR lokale Entwicklung (NODE_ENV darf nicht production sein, nur Loopback, Header x-dev-provision-key):
# CC_DEV_PROVISION_KEY=mindestens-8-zeichen-geheim
